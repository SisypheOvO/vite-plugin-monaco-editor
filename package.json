{
  "name": "vite-plugin-monaco-editor",
  "version": "1.1.0",
  "type": "module",
  "description": "A vite plugin for the Monaco Editor",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublish": "npm run copy:cdn",
    "format": "prettier --write . --end-of-line auto",
    "test:build": "npm run build && vite build --config test/vite.config.js",
    "test:dev": "npm run build && vite --config test/vite.config.js",
    "test:preview": "vite preview --config test/vite.config.js",
    "simulator:cdn": "http-server cdn/ --port 8888",
    "copy:cdn": "node script/updateCDN.cjs"
  },
  "files": [
    "dist",
    "cdn"
  ],
  "author": "china-bin",
  "license": "MIT",
  "keywords": [
    "vite-plugin",
    "monaco",
    "editor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vdesjs/vite-plugin-monaco-editor"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@okikio/sharedworker": "^1.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-sfc": "^3.5.32",
    "fs-extra": "^11.3.4",
    "http-server": "^14.1.1",
    "monaco-editor": "^0.52.2",
    "monaco-graphql": "^1.7.3",
    "prettier": "^3.8.1",
    "rolldown": "^1.0.0-rc.14",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.33.0"
  }
}
